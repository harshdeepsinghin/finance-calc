---
// src/components/Header.astro
---
<header id="global-header">
  <div class="logo-section" style="display: flex; align-items: center; gap: 0.75rem;">
    <button class="sidebar-toggle-btn" id="sidebar-toggle" aria-label="Toggle sidebar" style="margin-right: 0.25rem;">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <rect x="3" y="6" width="18" height="1.5" rx="0.75"/>
        <rect x="3" y="11.25" width="12" height="1.5" rx="0.75"/>
        <rect x="3" y="16.5" width="15" height="1.5" rx="0.75"/>
      </svg>
    </button>
    <a href="/index.html" style="display: flex; align-items: center; gap: 0.75rem; color: var(--text-primary); text-decoration: none;">
      <!-- Full Logo (Text Logo) -->
      <img src="/assets/MoneyInFuture_Logo_Light_Mode.png" class="logo-text-img logo-light" alt="MoneyInFuture" width="1108" height="385" />
      <img src="/assets/MoneyInFuture_Logo_Dark_Mode.png" class="logo-text-img logo-dark" alt="MoneyInFuture" width="1108" height="385" />
    </a>
  </div>
  
  <div class="header-actions-wrapper" id="header-actions-wrapper">
    <a href="/about.html" class="header-nav-link">About Us</a>
    <a href="/contact.html" class="header-nav-link">Contact Us</a>
    <div class="header-actions" style="display: flex; align-items: center; gap: 0.5rem;">
      <button class="preferences-btn" id="preferences-btn" aria-label="Preferences">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
        </svg>
      </button>
      <button class="search-toggle-btn" id="search-btn" aria-label="Search calculator">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>
      </button>
      <button class="theme-toggle-btn" aria-label="Toggle theme"></button>
    </div>
  </div>

  <button class="header-menu-toggle-btn" id="header-menu-toggle" aria-label="Toggle actions menu">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
      <rect x="3" y="6" width="18" height="1.5" rx="0.75"/>
      <rect x="3" y="11.25" width="18" height="1.5" rx="0.75"/>
      <rect x="3" y="16.5" width="18" height="1.5" rx="0.75"/>
    </svg>
  </button>
</header>
