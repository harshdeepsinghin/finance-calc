---
// src/components/OnboardingPopup.astro
---

<div id="onboarding-overlay" class="onboarding-overlay" style="display: none;">
  <div class="onboarding-card minimal-onboarding-card">
    <button id="onboarding-close-btn" class="onboarding-close-btn" aria-label="Close onboarding popup">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
      </svg>
    </button>
    
    <h3>Choose Finance Level</h3>
    <p>Customize terminology across the calculators to match your background:</p>
    
    <div class="onboarding-buttons">
      <button class="onboarding-btn-opt" data-level="simple" title="Simple mode (Beginner)">Simple</button>
      <button class="onboarding-btn-opt" data-level="investor" title="Investor mode (Intermediate)">Investor</button>
      <button class="onboarding-btn-opt" data-level="professional" title="Professional mode (Advanced)">Professional</button>
    </div>
    
    <div class="onboarding-info-link">
      <a href="/finance-levels.html" target="_blank">Learn more about these levels</a>
    </div>
  </div>
</div>
