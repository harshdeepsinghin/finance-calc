---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import OnboardingPopup from '../components/OnboardingPopup.astro';
import '../styles/style.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  loadEngine?: boolean;
}

const {
  title = 'MoneyInFuture - Blazing Fast Financial Calculators',
  description = 'Blazing-fast, zero-tracker, offline-first personal finance and mutual fund calculators tailored for Indian retail investors. Model SIP, Step-Up SIP, SWP, CAGR, XIRR, EMI and tax.',
  keywords = 'money in future, money in future website, moneyinfuture, moeny in future, my money will be in future, future money, financial calculators india, mutual fund calculator, sip step up, tax calculator, retirement planner india, emergency fund cagr, loan prepayment',
  loadEngine = false
} = Astro.props;

const currentPath = Astro.url.pathname;
const adsenseClientId = 'ca-pub-XXXXXXXXXXXXXX'; // Replace with your real publisher ID
const showAds = adsenseClientId && !adsenseClientId.includes('XXXXXXXXXXXXXX');
const socialImage = new URL('/assets/MoneyInFuture_Logo_Light_Mode.png', Astro.site || 'https://moneyinfuture.com').href;

// Clean canonical URL (no .html or /index.html)
let canonicalUrl = Astro.url.href;
if (canonicalUrl.endsWith('/index.html')) {
  canonicalUrl = canonicalUrl.replace(/\/index\.html$/, '/');
} else {
  canonicalUrl = canonicalUrl.replace(/\.html$/, '');
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="MoneyInFuture" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={socialImage} />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />
  
  <link rel="canonical" href={canonicalUrl} />
  
  <!-- Preconnect to external origins to optimize resource load times -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />
  {showAds && (
    <>
      <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
      <link rel="preconnect" href="https://googleads.g.doubleclick.net" crossorigin />
    </>
  )}
  
  <!-- Google AdSense -->
  {showAds && (
    <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`} crossorigin="anonymous"></script>
  )}

  <!-- Theme setup script to prevent light-flash (FOUC) -->
  <script is:inline>
    (() => {
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "MoneyInFuture",
      "alternateName": [
        "Money In Future",
        "Money in Future Website",
        "MoneyInFuture Website",
        "moeny in future",
        "my money will be in future",
        "future money"
      ],
      "url": "https://moneyinfuture.com/",
      "description": "Blazing-fast financial calculators for Indian retail investors on the Money in Future website."
    }
  </script>
  
  <slot name="head" />
</head>
<body>
  <div class="app-container">
    <Header />
    
    <div class="main-content">
      <Sidebar currentUrl={currentPath} />
      
      <main class="calculator-workspace">
        <slot />
      </main>
    </div>
    
    <Footer />
  </div>

  <OnboardingPopup />

  <!-- Dynamic Finance Glossary Tooltip -->
  <div id="finance-tooltip" class="finance-tooltip-box" style="opacity: 0; pointer-events: none; position: absolute; z-index: 10000;">
    <div class="tooltip-arrow"></div>
    <div class="tooltip-content">
      <p class="tooltip-definition"></p>
      <hr class="tooltip-divider" />
      <p class="tooltip-synonyms-list"></p>
    </div>
  </div>

  {loadEngine && <script src="/js/engine.js" defer></script>}
  <script src="/js/shared.js" defer></script>
</body>
</html>
