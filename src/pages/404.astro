---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
import { quotes } from '../data/quotes.js';
import { calculators } from '../data/calculators.js';

// Select 2 random calculators at build time
const randomCalcs = [];
const tempCalcs = [...calculators];
for (let i = 0; i < 2 && tempCalcs.length > 0; i++) {
  const randIdx = Math.floor(Math.random() * tempCalcs.length);
  randomCalcs.push(tempCalcs.splice(randIdx, 1)[0]);
}
---

<Layout 
  title="Error 404: Page Not Found | MoneyInFuture"
  description="This page has depreciated to zero value, but here's some compounding wisdom to keep you motivated."
>
  <div class="calculator-header error-header">
    <h1>Error 404: Page Not Found</h1>
    <p class="calculator-description">
      We couldn't find the page you were looking for. However, in personal finance, <strong>no asset is wasted if it leads to learning</strong>. 
      Here is some compounding wisdom to keep you motivated on your financial journey.
    </p>
  </div>

  <div class="error-container">
    <div class="quote-card">
      <!-- Inspire Me Button is kept above the quote to keep user cursor position stable -->
      <button class="btn btn-secondary" id="next-quote-btn" style="margin-bottom: 2rem; align-self: center; z-index: 10;">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 6px;">
          <path d="M12 6v3l4-4-4-4v3c-4.42 0-8 3.58-8 8 0 1.57.46 3.03 1.24 4.26L6.7 14.8c-.45-.83-.7-1.79-.7-2.8 0-3.31 2.69-6 6-6zm6.76 1.74L17.3 9.2c.44.84.7 1.79.7 2.8 0 3.31-2.69 6-6 6v-3l-4 4 4 4v-3c4.42 0 8-3.58 8-8 0-1.57-.46-3.03-1.24-4.26z"/>
        </svg>
        Inspire Me
      </button>

      <div class="quote-content-wrapper">
        <div class="quote-icon">“</div>
        <blockquote id="quote-text">
          Loading some financial wisdom...
        </blockquote>
        <cite id="quote-author">— Loading</cite>
      </div>
    </div>

    <!-- Navigation & Help Actions -->
    <div class="navigation-404" style="margin-top: 3rem; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.5rem;">
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
        <a href="/index.html" class="btn btn-primary" style="padding: 0.75rem 1.5rem; font-size: 0.95rem;">Go Back Home</a>
        <button class="btn btn-secondary" id="wasted-search-trigger-btn" style="padding: 0.75rem 1.5rem; font-size: 0.95rem;">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 4px;">
            <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
          </svg>
          Search Calculators
        </button>
      </div>
    </div>

    <!-- Play & Explore Section -->
    <div class="calculator-play-section">
      <h2>Come on and play here!</h2>
      <p>
        Don't let a 404 stop your compounding. Try running some numbers on these calculators:
      </p>
      
      <div class="dashboard-grid">
        {randomCalcs.map(item => (
          <a 
            href={`/calculators/${item.filename.replace('.html', '')}`} 
            class="calc-card"
          >
            <div>
              <h3>{item.title}</h3>
              <p>{item.metaDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ quotes }}>
    document.addEventListener('DOMContentLoaded', () => {
      const quoteText = document.getElementById('quote-text');
      const quoteAuthor = document.getElementById('quote-author');
      const nextBtn = document.getElementById('next-quote-btn');

      // Bind search button trigger
      const searchTrigger = document.getElementById('wasted-search-trigger-btn');
      if (searchTrigger) {
        searchTrigger.addEventListener('click', () => {
          const globalSearchBtn = document.getElementById('search-btn');
          if (globalSearchBtn) globalSearchBtn.click();
        });
      }

      let currentIndex = -1;

      function showRandomQuote() {
        if (!quotes || quotes.length === 0) return;
        
        let newIndex;
        // Avoid showing the same quote twice in a row if there are multiple quotes
        if (quotes.length > 1) {
          do {
            newIndex = Math.floor(Math.random() * quotes.length);
          } while (newIndex === currentIndex);
        } else {
          newIndex = 0;
        }

        currentIndex = newIndex;
        const quote = quotes[currentIndex];

        // Animate transition
        quoteText.style.opacity = 0;
        quoteAuthor.style.opacity = 0;

        setTimeout(() => {
          quoteText.textContent = quote.text;
          quoteAuthor.textContent = `— ${quote.author}`;
          quoteText.style.opacity = 1;
          quoteAuthor.style.opacity = 1;
        }, 200);
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', showRandomQuote);
      }

      // Initial quote
      showRandomQuote();
    });
  </script>
</Layout>

<style>
  .error-container {
    max-width: 800px;
    margin: 3rem auto;
    padding: 0 1rem;
  }

  .quote-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: var(--card-shadow);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .quote-content-wrapper {
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .quote-icon {
    font-size: 6rem;
    font-family: Georgia, serif;
    color: var(--border-color);
    position: absolute;
    top: -3.5rem;
    left: 0;
    opacity: 0.25;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  blockquote {
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--text-primary);
    margin: 0 0 1.25rem 0;
    transition: opacity 0.2s ease-in-out;
    z-index: 1;
    max-width: 600px;
    font-style: italic;
  }

  cite {
    font-size: 0.95rem;
    font-style: normal;
    font-weight: 600;
    color: var(--accent-color);
    transition: opacity 0.2s ease-in-out;
    z-index: 1;
    align-self: flex-end;
  }

  .calculator-play-section {
    margin-top: 4rem;
    border-top: 1px solid var(--border-color);
    padding-top: 3rem;
    text-align: center;
  }

  .calculator-play-section h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .calculator-play-section p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  /* Make calc cards flex nicely in the 404 grid */
  .calculator-play-section .dashboard-grid {
    text-align: left;
    margin-top: 1.5rem;
  }

  /* Red styling scoped to the 404 error header */
  .error-header h1 {
    color: #d70015; /* Elegant iOS light mode red */
  }

  :global([data-theme="dark"]) .error-header h1 {
    color: #ff453a; /* Elegant iOS dark mode red */
  }
</style>
